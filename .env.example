# Aplikasi
APP_NAME=Passenger Identity Verification System
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
DEBUG=false

# PostgreSQL (local development, tanpa Docker)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pivs

# CORS — dipisah koma, mis. http://localhost:3000,http://localhost:5173
CORS_ORIGINS=*

# Root folder penyimpanan file (KTP, wajah, boarding)
STORAGE_ROOT=storage

# OCR (PaddleOCR)
OCR_LANG=en
# oneDNN dimatikan default: pada paddlepaddle 3.3 + CPU tertentu, OCR gagal total
# dengan "ConvertPirAttribute2RuntimeAttribute not support". Set true bila mesin
# Anda mendukungnya (lebih cepat).
OCR_ENABLE_MKLDNN=false

# Face Recognition — pipeline: RetinaFace ResNet50 (ONNX) -> alignment -> FaceNet
#
# Backend inference. Pipeline & model SAMA; hanya cara inference yang beda.
#   cpu   -> onnxruntime (CPU/GPU laptop) + facenet-pytorch
#   metis -> Axelera Runtime (model .onnx yang sama; menyusul)
FACE_ENGINE=cpu

# RetinaFace ResNet50 ONNX — parameter = model card resmi Axelera
# 'retinaface-resnet50-widerface-onnx' (input 840x840). Default URL menunjuk
# artefak resmi Axelera; dibiarkan kosong = pakai file lokal saja.
RETINAFACE_MODEL_PATH=models/Retinaface_resnet50_840.onnx
RETINAFACE_MODEL_URL=https://media.axelera.ai/artifacts/model_cards/weights/others/object_detection/Retinaface_resnet50_840.onnx
RETINAFACE_MODEL_MD5=2c3dbe322cd8ca067e5bb561e0850513
RETINAFACE_INPUT_SIZE=840
RETINAFACE_CONF_THRESHOLD=0.2
RETINAFACE_NMS_THRESHOLD=0.4

# Ambang kualitas foto wajah saat registrasi. Foto acuan yang buruk merusak
# SEMUA verifikasi penumpang itu kelak, jadi ambangnya sengaja ketat di sini.
FACE_MIN_DET_SCORE=0.60
FACE_MIN_SIZE_PX=80
FACE_MIN_SHARPNESS=40
FACE_MIN_BRIGHTNESS=50
FACE_MAX_BRIGHTNESS=220
FACE_MAX_YAW=30
FACE_MAX_PITCH=30
FACE_MIN_QUALITY_SCORE=0.45

# Ambang kecocokan wajah (cosine similarity antar embedding, rentang -1..1).
# Naikkan bila keamanan lebih penting daripada kenyamanan; turunkan bila
# penumpang terlalu sering ditolak padahal orangnya benar.
FACE_MATCH_THRESHOLD=0.75

# =====================================================================
# KAMERA
# =====================================================================
# 0 = kamera laptop
# 1 = webcam eksternal (USB)
# Cek daftar: python tools/capture_face.py --list-cameras
CAMERA_INDEX=0

CAMERA_WIDTH=640
CAMERA_HEIGHT=480

# Ambang deteksi wajah GANDA saat registrasi (lihat .env)
FACE_DUPLICATE_THRESHOLD=0.65

# Enkripsi NIK
ENCRYPTION_KEY=your-secret-encryption-key-here
